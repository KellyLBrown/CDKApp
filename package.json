{
  "name": "cdk-starter",
  "version": "0.2.2",
  "description": "Scaffold production-ready AWS CDK apps from curated starters",
  "keywords": [
    "aws",
    "cdk",
    "scaffolding",
    "infrastructure",
    "typescript"
  ],
  "author": "kellybrown",
  "license": "MIT",
  "homepage": "https://www.cdkapp.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KellyLBrown/CDKApp.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cdk-starter": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/core": "^1.1.0",
    "@clack/prompts": "^1.1.0",
    "degit": "^2.8.4",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/degit": "^2.8.6",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
